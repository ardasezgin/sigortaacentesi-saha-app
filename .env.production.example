# Aksiyon Saha Uygulaması - Production Environment Variables
# Bu dosyayı .env.production olarak kopyalayın ve değerleri doldurun

# Node Environment
NODE_ENV=production

# Database Configuration
POSTGRES_DB=aksiyon_db
POSTGRES_USER=aksiyon_user
POSTGRES_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD

# Database URL (Docker Compose otomatik oluşturur, manuel kurulumda düzenleyin)
DATABASE_URL=postgresql://aksiyon_user:CHANGE_THIS_TO_STRONG_PASSWORD@db:5432/aksiyon_db

# Server Configuration
PORT=3000
HOST=0.0.0.0

# ClickUp API
# ClickUp Personal API Token alın: https://app.clickup.com/settings/apps
CLICKUP_API_TOKEN=pk_YOUR_CLICKUP_TOKEN_HERE

# Session Secret
# Güvenli bir random string oluşturun: openssl rand -hex 64
SESSION_SECRET=CHANGE_THIS_TO_RANDOM_64_CHAR_STRING

# Domain (SSL için - opsiyonel)
DOMAIN=api.sigortaacentesi.com

# Logging (opsiyonel)
LOG_LEVEL=info

# CORS (opsiyonel)
CORS_ORIGIN=*
